use Int
use Test

test "Int.abs"
  Test.assert(Int.abs(-5) == 5)

test "Int.min_max_clamp"
  Test.assert(Int.min(2, 9) == 2)
  Test.assert(Int.max(2, 9) == 9)
  Test.assert(Int.clamp(12, 0, 10) == 10)

test "Int.to_float"
  let f = Int.to_float(42)
  Test.assert(f > 41.9 and f < 42.1)
  let neg = Int.to_float(-10)
  Test.assert(neg < -9.9 and neg > -10.1)
