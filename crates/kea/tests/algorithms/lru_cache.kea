doc
  LRU cache (least-recently-used eviction) — functional implementation.

  An LRU cache stores up to `cap` key-value pairs. When a new entry would
  exceed capacity, the least-recently-used entry is evicted. On every
  access (get or put), the entry moves to the front of the recency list.

  ## Structure

  State is a pair `(List CacheEntry, Int)`:
  - `entries` — a list of `CacheEntry` records ordered most-recently-used
                 to least-recently-used (front = most recent).
  - `cap`      — maximum number of entries.

  ```
  cap = 3, entries = [ {3,c}, {1,a}, {2,b} ]
                       ^^^                     most recently used
                                        ^^^   least recently used
  ```

  ## Complexity

  | Operation | Time |
  |-----------|------|
  | get       | O(n) — linear scan to find key, then list rebuild |
  | put       | O(n) — linear scan to remove old entry, prepend, trim |

  This is the straightforward functional implementation. A production LRU
  cache would use a doubly-linked list with a hash map for O(1) operations;
  see the `Map` stdlib for the hash map half of that design.

  ## Cross-language notes

  Imperative languages typically implement LRU with a `HashMap<K, Node>` and
  a doubly-linked list. The functional version here trades O(1) time for
  simplicity: no mutable pointers, no unsafe code, and straightforward
  correctness reasoning.

use List
use Test

-- -----------------------------------------------------------------------
-- Types
-- -----------------------------------------------------------------------

doc
  A single cache entry.
struct CacheEntry
  key: Int
  val: Int

doc
  An LRU cache with a fixed capacity.
  `entries` is ordered most-recently-used first.
struct Cache
  entries: List CacheEntry
  cap:     Int

-- -----------------------------------------------------------------------
-- Construction
-- -----------------------------------------------------------------------

doc
  Create an empty LRU cache with the given capacity.

    let c = new(3)   -- empty cache, max 3 entries
fn new(cap: Int) -> Cache
  Cache { entries: Nil, cap: if cap > 0 then cap else 1 }

-- -----------------------------------------------------------------------
-- Internal helpers
-- -----------------------------------------------------------------------

-- Remove the first entry with `key` from the list, collecting the rest.
fn remove_key(xs: List CacheEntry, key: Int) -> (List CacheEntry, Option CacheEntry)
  remove_key_acc(xs, key, Nil)

fn remove_key_acc(xs: List CacheEntry, key: Int, acc: List CacheEntry) -> (List CacheEntry, Option CacheEntry)
  case xs
    Nil ->
      (List.reverse(acc), None)
    Cons(e, rest) ->
      if e.key == key
        (List.append(List.reverse(acc), rest), Some(e))
      else
        remove_key_acc(rest, key, Cons(e, acc))

-- Keep only the first `n` elements of a list.
fn take(xs: List CacheEntry, n: Int) -> List CacheEntry
  if n <= 0
    Nil
  else
    case xs
      Nil -> Nil
      Cons(x, rest) -> Cons(x, take(rest, n - 1))

-- -----------------------------------------------------------------------
-- Public API
-- -----------------------------------------------------------------------

doc
  Look up `key` in the cache.
  Returns `(updated_cache, Some(val))` on hit, or `(cache, None)` on miss.
  A hit promotes the entry to most-recently-used.

    let c0 = put(put(new(3), 1, "a"), 2, "b")
    let result = get(c0, 1)     -- hit; 1 moves to front
    result.1                    -- => Some("a")
fn get(c: Cache, key: Int) -> (Cache, Option Int)
  let removed = remove_key(c.entries, key)
  let rest = removed.0
  let found = removed.1
  case found
    None ->
      (c, None)
    Some(e) ->
      -- Re-insert at front (most recently used).
      let new_entries = Cons(e, rest)
      (Cache { entries: new_entries, cap: c.cap }, Some(e.val))

doc
  Insert or update `key -> val` in the cache.
  If the key is already present, it is updated and moved to the front.
  If the cache is at capacity after insertion, the LRU entry is evicted.
  Returns the updated cache.

    let c0 = new(2)
    let c1 = put(c0, 1, 10)
    let c2 = put(c1, 2, 20)
    let c3 = put(c2, 3, 30)   -- evicts key 1 (LRU)
    get(c3, 1)                -- => (c3, None)
fn put(c: Cache, key: Int, val: Int) -> Cache
  -- Remove old entry for this key if present.
  let removed = remove_key(c.entries, key)
  let rest = removed.0
  -- Prepend new entry at front.
  let new_entry = CacheEntry { key: key, val: val }
  let full = Cons(new_entry, rest)
  -- Trim to capacity.
  let trimmed = take(full, c.cap)
  Cache { entries: trimmed, cap: c.cap }

doc
  Return the number of entries currently in the cache.
fn size(c: Cache) -> Int
  List.length(c.entries)

-- -----------------------------------------------------------------------
-- Test helpers
-- -----------------------------------------------------------------------

fn unwrap_or(opt: Option Int, default: Int) -> Int
  case opt
    Some(x) -> x
    None    -> default

fn is_none_opt(opt: Option Int) -> Bool
  case opt
    Some(_) -> false
    None    -> true

-- -----------------------------------------------------------------------
-- Tests
-- -----------------------------------------------------------------------

test "new cache is empty"
  let c = new(3)
  Test.assert(size(c) == 0)
  let result = get(c, 1)
  Test.assert(is_none_opt(result.1))

test "put and get round-trip"
  let c0 = new(4)
  let c1 = put(c0, 1, 10)
  let c2 = put(c1, 2, 20)
  let c3 = put(c2, 3, 30)
  let r1 = get(c3, 1)
  let r2 = get(c3, 2)
  let r3 = get(c3, 3)
  Test.assert(unwrap_or(r1.1, -1) == 10)
  Test.assert(unwrap_or(r2.1, -1) == 20)
  Test.assert(unwrap_or(r3.1, -1) == 30)

test "get miss returns None"
  let c = put(new(4), 1, 10)
  let result = get(c, 99)
  Test.assert(is_none_opt(result.1))

test "put evicts LRU when at capacity"
  -- Insert 1, 2, 3 into a capacity-2 cache.
  -- After inserting 3, key 1 (the LRU) should be evicted.
  let c0 = new(2)
  let c1 = put(c0, 1, 10)
  let c2 = put(c1, 2, 20)
  let c3 = put(c2, 3, 30)
  let r1 = get(c3, 1)
  let r2 = get(c3, 2)
  let r3 = get(c3, 3)
  Test.assert(is_none_opt(r1.1))    -- evicted
  Test.assert(unwrap_or(r2.1, -1) == 20)
  Test.assert(unwrap_or(r3.1, -1) == 30)

test "get promotes to most recently used"
  -- Insert 1 and 2 (cap=2). Access 1 to promote it.
  -- Then insert 3 — should evict 2 (now LRU), not 1.
  let c0 = new(2)
  let c1 = put(c0, 1, 10)
  let c2 = put(c1, 2, 20)
  -- Access key 1 (promotes it to front)
  let c3 = get(c2, 1).0
  -- Insert key 3 — 2 is now LRU, should be evicted
  let c4 = put(c3, 3, 30)
  let r1 = get(c4, 1)
  let r2 = get(c4, 2)
  let r3 = get(c4, 3)
  Test.assert(unwrap_or(r1.1, -1) == 10)
  Test.assert(is_none_opt(r2.1))    -- evicted
  Test.assert(unwrap_or(r3.1, -1) == 30)

test "put overwrites existing key without growing"
  let c0 = new(3)
  let c1 = put(c0, 1, 10)
  let c2 = put(c1, 2, 20)
  let c3 = put(c2, 1, 99)   -- update key 1
  Test.assert(size(c3) == 2)
  let r = get(c3, 1)
  Test.assert(unwrap_or(r.1, -1) == 99)

test "size respects capacity"
  let c0 = new(2)
  let c1 = put(c0, 1, 1)
  let c2 = put(c1, 2, 2)
  let c3 = put(c2, 3, 3)
  let c4 = put(c3, 4, 4)
  Test.assert(size(c4) == 2)

test "capacity 1 keeps only the most recent entry"
  let c0 = new(1)
  let c1 = put(c0, 1, 10)
  let c2 = put(c1, 2, 20)
  let c3 = put(c2, 3, 30)
  Test.assert(size(c3) == 1)
  let r1 = get(c3, 1)
  let r2 = get(c3, 2)
  let r3 = get(c3, 3)
  Test.assert(is_none_opt(r1.1))
  Test.assert(is_none_opt(r2.1))
  Test.assert(unwrap_or(r3.1, -1) == 30)

test "eviction sequence: LRU order is maintained"
  -- Insert 1,2,3 into cap-3. Access 1 (now MRU). Insert 4 (evicts 2).
  let c0 = new(3)
  let c1 = put(c0, 1, 1)
  let c2 = put(c1, 2, 2)
  let c3 = put(c2, 3, 3)
  -- Order: [3, 2, 1] — 1 is LRU
  let c4 = get(c3, 1).0
  -- Order: [1, 3, 2] — 2 is LRU
  let c5 = put(c4, 4, 4)
  -- Order: [4, 1, 3] — 2 evicted
  let r1 = get(c5, 1)
  let r2 = get(c5, 2)
  let r3 = get(c5, 3)
  let r4 = get(c5, 4)
  Test.assert(unwrap_or(r1.1, -1) == 1)
  Test.assert(is_none_opt(r2.1))    -- evicted
  Test.assert(unwrap_or(r3.1, -1) == 3)
  Test.assert(unwrap_or(r4.1, -1) == 4)
